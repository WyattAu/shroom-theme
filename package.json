{
  "name": "shroom-space-theme",
  "displayName": "Shroom Space Theme",
  "description": "Cosmic dark theme with 7 variants: dark, light, deuteranopia, protanopia, tritanopia, monochrome, high contrast. WCAG 2.1 AA, 943 tokens, semantic highlighting, accent color customization, 9-format export.",
  "version": "4.0.0",
  "publisher": "wyattau",
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "author": "Wyatt Au <wyatt_au@protonmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WyattAu/shroom-theme.git"
  },
  "keywords": [
    "vscode",
    "theme",
    "shroom",
    "space",
    "dark",
    "light",
    "cvd",
    "color-blind",
    "deuteranopia",
    "protanopia",
    "tritanopia",
    "high-contrast",
    "monochrome",
    "accessibility",
    "wcag",
    "cosmic",
    "purple",
    "teal",
    "pastel",
    "minimal",
    "modern",
    "retina",
    "comfortable",
    "low-vision",
    "a11y"
  ],
  "homepage": "https://wyattau.github.io/shroom-theme/",
  "bugs": {
    "url": "https://github.com/WyattAu/shroom-theme/issues"
  },
  "engines": {
    "vscode": "^1.120.0",
    "node": ">=24.0.0"
  },
  "categories": [
    "Themes"
  ],
  "galleryBanner": {
    "color": "#24212E",
    "theme": "dark"
  },
  "icon": "icon.png",
  "screenshots": [
    {
      "path": "screenshots/shroom-space-theme.png"
    },
    {
      "path": "screenshots/shroom-space-light-theme.png"
    },
    {
      "path": "screenshots/shroom-space-deuteranopia-theme.png"
    }
  ],
  "contributes": {
    "themes": [
      {
        "label": "Shroom Space",
        "uiTheme": "vs-dark",
        "path": "./themes/shroom-space-theme.json"
      },
      {
        "label": "Shroom Space Light",
        "uiTheme": "vs",
        "path": "./themes/shroom-space-light-theme.json"
      },
      {
        "label": "Shroom Space (Deuteranopia)",
        "uiTheme": "vs-dark",
        "path": "./themes/shroom-space-deuteranopia-theme.json"
      },
      {
        "label": "Shroom Space (Protanopia)",
        "uiTheme": "vs-dark",
        "path": "./themes/shroom-space-protanopia-theme.json"
      },
      {
        "label": "Shroom Space (Tritanopia)",
        "uiTheme": "vs-dark",
        "path": "./themes/shroom-space-tritanopia-theme.json"
      },
      {
        "label": "Shroom Space (Monochrome)",
        "uiTheme": "vs-dark",
        "path": "./themes/shroom-space-monochrome-theme.json"
      },
      {
        "label": "Shroom Space (High Contrast)",
        "uiTheme": "hc-black",
        "path": "./themes/shroom-space-high-contrast-theme.json"
      }
    ],
    "configuration": {
      "title": "Shroom Space Theme",
      "properties": {
        "shroom-space.accentColor": {
          "type": "string",
          "enum": [
            "default",
            "purple",
            "teal",
            "green",
            "amber",
            "red",
            "pink",
            "cyan",
            "custom"
          ],
          "enumDescriptions": [
            "Use theme default accent colors",
            "Purple accent (keywords, highlights)",
            "Teal accent (functions, info)",
            "Green accent (strings, additions)",
            "Amber accent (constants, types)",
            "Red accent (errors, deletions)",
            "Pink accent (variables, decorators)",
            "Cyan accent (types, interfaces)",
            "Custom accent from HSL values (set via customAccentHsl)"
          ],
          "default": "default",
          "description": "Override the primary accent color for syntax highlighting",
          "order": 1
        },
        "shroom-space.customAccentHsl": {
          "type": "string",
          "default": "",
          "description": "Custom accent color as HSL values (format: 'hue,saturation,lightness' e.g. '280,70,80'). Only used when accentColor is 'custom'.",
          "order": 3
        },
        "shroom-space.autoSwitch": {
          "type": "boolean",
          "default": false,
          "description": "Automatically switch between dark and light themes based on OS appearance",
          "order": 2
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "validate": "node validate-themes.js",
    "convert": "node tools/convert.js",
    "generate-visual-pages": "node tools/generate-theme-html.js",
    "test:visual": "npm run generate-visual-pages && npx playwright test -c tests/visual/playwright.config.ts",
    "test:visual:update": "rm -rf tests/visual/references && npm run test:visual",
    "pretest": "npm run compile && npm run lint && npm run validate",
    "lint": "eslint src",
    "test": "vscode-test",
    "sbom": "node tools/generate-sbom.js",
    "test:ci": "npm run compile && npm run lint && npm run validate && npm run convert && npm run test:visual && npm run sbom"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/pixelmatch": "^5.2.6",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.120.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "chai": "^6.2.2",
    "eslint": "^10.4.0",
    "mocha": "^11.3.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "sinon": "^22.0.0",
    "typescript": "^6.0.3"
  }
}
